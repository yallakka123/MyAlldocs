name: Stable Incremental Deployment

on:
 workflow_dispatch:
   inputs:
     run_target:
       description: "Stable"
       required: true
       default: "src"

jobs:
 usingsfdx:
   runs-on: ubuntu-latest
   steps:
   - name: 'Checkout source code'
     uses: actions/checkout@v3
     with:
       fetch-depth: 200
   - name: Git Log
     run: |
         git log --oneline


   - name: 'Set up JDK 1.8'
     uses: actions/setup-java@v3
     with:
        java-version: '17'
        distribution: 'zulu'

  
   - name: 'Install SFDX'
     run: |
         npm install @salesforce/cli --global

   - name: Install SGD
     run: |
         echo y | sfdx plugins:install sfdx-git-delta
         pwd

   - name: Building Package SGD
     run: |
         sfdx sgd:source:delta --to "HEAD" --from "${{ vars.STABLE_STARTCOMMIT }}" --output-dir "." --source-dir src/
   - name: Package
     run: |
         echo " ------ Package ------"
         cat package/package.xml
         echo " ---------------------"
         echo "                       "
         echo " ------ Destructive Package------"
         cat destructiveChanges/destructiveChanges.xml
         echo "---------------------------------"


   - name: sfdx authorization
     run: |
         echo ${{ secrets.STABLE_AUTHURL}} > SF_envnameLogin_URL.txt
         sf org login sfdx-url --sfdx-url-file SF_envnameLogin_URL.txt

   - name: Deploy Package
     run: |
       sf project deploy start -x package/package.xml -o ${{ secrets.STABLE_USERNAME}} --post-destructive-changes destructiveChanges/destructiveChanges.xml --ignore-warnings --ignore-conflicts


   - name: Saving last successfull commit
     run: |
         curl -L -X PATCH \
         -H "Accept: application/vnd.github+json" \
         -H "Authorization: Bearer ${{ secrets.PUCT_PAT }}" \
         -H "X-GitHub-Api-Version: 2022-11-28" \
         -d '{"name":"STABLE_STARTCOMMIT","value":"'"$(git rev-parse HEAD)"'"}' \explain this indetail work fow
